{
  "name": "@casuya/editor",
  "version": "0.1.0",
  "private": true,
  "description": "Visual lesson builder for Casuya — drag-and-drop educational content creation without programming.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casuya-co-tz/casuya-editor.git"
  },
  "bugs": {
    "url": "https://github.com/casuya-co-tz/casuya-editor/issues"
  },
  "author": "Casuya",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "education",
    "lesson-builder",
    "visual-editor",
    "casuya"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "typescript": "5.7",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
