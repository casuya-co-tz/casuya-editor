{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@casuya-editor/*": ["./*"]
    }
  },
  "include": [
    "src",
    "visual-builder",
    "component-library",
    "templates",
    "previews",
    "autosave",
    "importers",
    "exporters",
    "assets",
    "themes",
    "versioning",
    "accessibility",
    "utilities",
    "tests",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
